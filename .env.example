# Meshy AI API anahtarı - REMURA 3D AI (görsel → 3D model) için gerekli
# https://app.meshy.ai/settings adresinden oluşturun
MESHY_API_KEY=

# OpenAI API anahtarı - Remaura AI görsel üretimi için gerekli
# https://platform.openai.com/api-keys adresinden "Create new secret key" ile oluşturun
# Format: OPENAI_API_KEY=sk-proj-xxxxxxxx (tırnak yok, = etrafında boşluk yok)
OPENAI_API_KEY=

# Replicate API - Derinlik haritası ve normal map üretimi için (opsiyonel)
# https://replicate.com/account/api-tokens adresinden oluşturun
REPLICATE_API_TOKEN=

# Sanal POS webhook imzalama anahtari (banka entegrasyonunda kullanilacak)
VPOS_WEBHOOK_SECRET=

# Site URL (checkout link uretilmesi icin)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanal POS provider secimi: mock | halkbank
VPOS_PROVIDER=mock

# Halkbank sanal POS (gercek canli entegrasyonda doldurulacak)
HALKBANK_CHECKOUT_BASE_URL=
HALKBANK_MERCHANT_ID=
HALKBANK_CURRENCY=TRY

# --- Cron (dashboard PDF, gider yedek PDF vb.) ---
# Vercel Cron veya harici scheduler: Authorization: Bearer <CRON_SECRET>
# Gider yedek: GET /api/cron/finance-expense-backup (vercel.json: 0 21 * * * UTC ≈ TR gece 00:00)
CRON_SECRET=
# PDF alıcı e-posta (SMTP dolu olmalı)
REPORT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL_FROM=
# Zapier/Make veya özel uploader — JSON gövdesinde pdfBase64 alanı gelir
REPORT_DELIVERY_WEBHOOK_URL=
REPORT_WEBHOOK_SECRET=
